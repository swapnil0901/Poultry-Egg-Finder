DATABASE_URL=postgres://postgres:postgres@localhost:5432/poultry_egg_finder
# Optional aliases
DATABASE_INTERNAL_URL=
NODE_ENV=development
# Frontend API target for static hosts like Netlify (e.g. https://your-backend.up.railway.app)
VITE_API_BASE_URL=
# Comma-separated frontend origins allowed to call this backend
CORS_ORIGINS=

# Optional AI keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Smart alert thresholds
FEED_STOCK_ALERT_THRESHOLD_KG=10
EGG_DROP_ALERT_THRESHOLD_PERCENT=20
MORTALITY_INCREASE_ALERT_THRESHOLD_PERCENT=25
EGG_COLLECTION_NOTIFY_THRESHOLD=1
DISEASE_AFFECTED_NOTIFY_THRESHOLD=1
VACCINATION_REMINDER_DAYS_BEFORE=1

# Fast2SMS alerts
ENABLE_SMS_ALERTS=true
ALERT_PROVIDER=auto
NOTIFICATION_PROVIDER=auto
FAST2SMS_API_KEY=
FARM_OWNER_PHONE=
FAST2SMS_ROUTE=q

# Twilio SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_SMS_TO=

# Twilio WhatsApp alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+917666726169
FARM_OWNER_WHATSAPP=
TWILIO_CONTENT_SID=

# IoT bridge
ARDUINO_COM_PORT=COM15
ARDUINO_BAUD_RATE=9600
BACKEND_DATA_URL=https://poultrymanager.vercel.app/api/data
BACKEND_CONTROL_URL=https://poultrymanager.vercel.app/api/control
REQUEST_TIMEOUT_MS=10000
CONTROL_POLL_INTERVAL_MS=1500
SENSOR_POST_INTERVAL_MS=2000
